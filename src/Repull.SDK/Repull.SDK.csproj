<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <NoWarn>$(NoWarn);CS1591;CS0618</NoWarn>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>

    <PackageId>Repull.SDK</PackageId>
    <Version>0.2.3</Version>
    <Authors>Repull</Authors>
    <Company>Repull</Company>
    <Product>Repull .NET SDK</Product>
    <Description>.NET SDK for Repull — the unified API for vacation rental tech. Generated from OpenAPI via Kiota.</Description>
    <PackageTags>repull;vacation-rental;hospitality;pms;airbnb;booking;ota;sdk</PackageTags>
    <PackageProjectUrl>https://github.com/ivannikolovbg/repull-dotnet</PackageProjectUrl>
    <RepositoryUrl>https://github.com/ivannikolovbg/repull-dotnet</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Kiota.Bundle" Version="1.22.1" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="\" Condition="Exists('../../README.md')" />
  </ItemGroup>

</Project>
